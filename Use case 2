<!DOCTYPE html>
<html>
<head>
<title>Search Interface with Live Filtering</title>

<style>
body{
font-family: Arial;
background:#f2f2f2;
text-align:center;
}

h1{
color:#333;
}

#searchBox{
width:50%;
padding:10px;
font-size:16px;
margin-bottom:20px;
border:1px solid #ccc;
border-radius:5px;
}

ul{
list-style:none;
padding:0;
width:50%;
margin:auto;
}

li{
background:white;
margin:5px;
padding:10px;
border-radius:5px;
box-shadow:0 0 5px rgba(0,0,0,0.1);
}
</style>

</head>

<body>

<h1>Live Search Interface</h1>

<input type="text" id="searchBox" placeholder="Search items..." onkeyup="searchFunction()">

<ul id="itemList">
<li>Web development </li>
<li>Artificial intelligence </li>
<li>Machine learning </li>
<li>Data science </li>
<li>Cloud computing</li>
<li>Cyber security </li>
<li>Mobile app development </li>
<li>Data bade management </li>
</ul>

<script>

function searchFunction(){
let input=document.getElementById("searchBox");
let filter=input.value.toLowerCase();
let ul=document.getElementById("itemList");
let li=ul.getElementsByTagName("li");

for(let i=0;i<li.length;i++){
let text=li[i].textContent;

if(text.toLowerCase().indexOf(filter)>-1){
li[i].style.display="";
}
else{
li[i].style.display="none";
}
}
}

</script>

</body>
</html>
