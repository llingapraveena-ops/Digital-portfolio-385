<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Multi Section Webpage</title>

<style>

body{
font-family: Arial, sans-serif;
margin:0;
padding:0;
}

/* Header */
header{
background:#333;
color:white;
text-align:center;
padding:20px;
}

/* Navigation */
nav{
background:#555;
}

nav ul{
list-style:none;
display:flex;
justify-content:center;
margin:0;
padding:0;
}

nav ul li{
margin:10px;
}

nav ul li a{
color:white;
text-decoration:none;
font-size:18px;
padding:8px 15px;
}

nav ul li a:hover{
background:#222;
border-radius:5px;
}

/* Sections */
section{
padding:40px;
text-align:center;
}

#about{
background:#f4f4f4;
}

#services{
background:#e2e2e2;
}

#contact{
background:#f4f4f4;
}

/* Services Box */
.service-box{
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
}

.box{
background:white;
padding:20px;
width:200px;
border-radius:8px;
box-shadow:0 0 5px gray;
}

/* Contact Form */
form{
max-width:400px;
margin:auto;
}

input,textarea{
width:100%;
padding:10px;
margin:10px 0;
}

button{
background:#333;
color:white;
padding:10px 20px;
border:none;
cursor:pointer;
}

button:hover{
background:#555;
}

/* Footer */
footer{
background:#333;
color:white;
text-align:center;
padding:10px;
}

/* Responsive */
@media (max-width:600px){

nav ul{
flex-direction:column;
align-items:center;
}

.service-box{
flex-direction:column;
align-items:center;
}

}

</style>
</head>

<body>

<!-- Header -->
<header>
<h1>My Website</h1>
<p>Simple Multi Section Webpage</p>
</header>

<!-- Navigation -->
<nav>
<ul>
<li><a href="#home">Home</a></li>
<li><a href="#about">About</a></li>
<li><a href="#services">Services</a></li>
<li><a href="#contact">Contact</a></li>
</ul>
</nav>

<!-- Home Section -->
<section id="home">
<h2>Welcome</h2>
<p>This is a basic responsive multi-section webpage built using HTML and CSS.</p>
</section>

<!-- About Section -->
<section id="about">
<h2>About Us</h2>
<p>We provide simple web design and front-end development services for beginners and small businesses.</p>
</section>

<!-- Services Section -->
<section id="services">
<h2>Our Services</h2>

<div class="service-box">

<div class="box">
<h3>Web Design</h3>
<p>Creating simple and attractive website designs.</p>
</div>

<div class="box">
<h3>Front-End Development</h3>
<p>Building responsive websites using HTML, CSS and JavaScript.</p>
</div>

<div class="box">
<h3>UI Design</h3>
<p>Designing user friendly interfaces for websites.</p>
</div>

</div>

</section>

<!-- Contact Section -->
<section id="contact">
<h2>Contact Us</h2>

<form>
<input type="text" placeholder="Enter your name" required>
<input type="email" placeholder="Enter your email" required>
<textarea placeholder="Enter your message"></textarea>
<button type="submit">Submit</button>
</form>

</section>

<!-- Footer -->
<footer>
<p>© 2026 My Website | All Rights Reserved</p>
</footer>

</body>
</html>
