<!DOCTYPE html>
<html>
<head>
<title>Responsive Product Grid</title>

<style>

body{
font-family: Arial;
background-color:#f4f4f4;
margin:0;
padding:20px;
}

h1{
text-align:center;
}

.product-container{
display:grid;
grid-template-columns:repeat(auto-fit, minmax(200px,1fr));
gap:20px;
}

.product-card{
background:white;
border-radius:10px;
padding:15px;
text-align:center;
box-shadow:0 2px 5px rgba(0,0,0,0.2);
}

.product-card img{
width:100%;
height:150px;
object-fit:cover;
border-radius:5px;
}

.product-card h3{
margin:10px 0;
}

.price{
color:green;
font-weight:bold;
}

button{
background:blue;
color:white;
border:none;
padding:8px 12px;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:darkblue;
}

</style>

</head>

<body>

<h1>Product Catalog</h1>

<div class="product-container">

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 1</h3>
<p class="price">$20</p>
<button>Buy Now</button>
</div>

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 2</h3>
<p class="price">$25</p>
<button>Buy Now</button>
</div>

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 3</h3>
<p class="price">$30</p>
<button>Buy Now</button>
</div>

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 4</h3>
<p class="price">$35</p>
<button>Buy Now</button>
</div>

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 5</h3>
<p class="price">$40</p>
<button>Buy Now</button>
</div>

<div class="product-card">
<img src="https://via.placeholder.com/200">
<h3>Product 6</h3>
<p class="price">$45</p>
<button>Buy Now</button>
</div>

</div>

</body>
</html>
