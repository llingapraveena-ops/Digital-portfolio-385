<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Activity Tracker</title>

<style>
    body {
        font-family: Arial, sans-serif;
        margin: 0;
        background-color: #f4f6f8;
    }

    header {
        background-color: #2c3e50;
        color: white;
        padding: 15px;
        text-align: center;
    }

    nav {
        background-color: #34495e;
        padding: 10px;
        text-align: center;
    }

    nav button {
        background-color: #ecf0f1;
        border: none;
        padding: 10px 15px;
        margin: 5px;
        cursor: pointer;
        border-radius: 5px;
        font-weight: bold;
    }

    nav button:hover {
        background-color: #bdc3c7;
    }

    section {
        padding: 20px;
        display: none;
    }

    .active {
        display: block;
    }

    .card {
        background: white;
        padding: 15px;
        margin: 10px 0;
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .status {
        font-weight: bold;
    }

    .pending {
        color: red;
    }

    .completed {
        color: green;
    }

    .complete-btn {
        background-color: #27ae60;
        color: white;
        border: none;
        padding: 8px 12px;
        border-radius: 5px;
        cursor: pointer;
        margin-top: 10px;
    }

    .complete-btn:hover {
        background-color: #219150;
    }

    .progress-box {
        background: white;
        padding: 20px;
        border-radius: 8px;
        font-size: 18px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    footer {
        text-align: center;
        padding: 10px;
        background-color: #2c3e50;
        color: white;
        margin-top: 20px;
    }
</style>
</head>

<body>

<header>
    <h1>Student Activity Tracker</h1>
    <p>Track your learning activities easily</p>
</header>

<nav>
    <button onclick="showSection('home')">Home</button>
    <button onclick="showSection('activities')">Activities</button>
    <button onclick="showSection('progress')">Progress</button>
</nav>

<section id="home" class="active">
    <h2>Welcome</h2>
    <p>
        This simple web application helps students manage their learning tasks,
        update activity status, and monitor overall progress.
    </p>
</section>

<section id="activities">
    <h2>Activity List</h2>
    <div id="activityList"></div>
</section>

<section id="progress">
    <h2>Progress Summary</h2>
    <div class="progress-box" id="progressBox"></div>
</section>

<footer>
    © 2026 Student Activity Tracker
</footer>

<script>
    const activities = [
        { id: 1, name: "HTML Practice", desc: "Complete basic HTML exercises", completed: false },
        { id: 2, name: "CSS Styling", desc: "Design responsive web pages", completed: false },
        { id: 3, name: "JavaScript Basics", desc: "Learn JS fundamentals", completed: true },
        { id: 4, name: "Mini Project", desc: "Build a small web app", completed: false },
        { id: 5, name: "Debugging Practice", desc: "Fix common coding errors", completed: false },
        { id: 6, name: "Mock Interview Prep", desc: "Prepare technical questions", completed: false }
    ];

    function showSection(sectionId) {
        document.querySelectorAll("section").forEach(sec => sec.classList.remove("active"));
        document.getElementById(sectionId).classList.add("active");
    }

    function renderActivities() {
        const list = document.getElementById("activityList");
        list.innerHTML = "";

        activities.forEach(activity => {
            const card = document.createElement("div");
            card.className = "card";

            const statusClass = activity.completed ? "completed" : "pending";
            const statusText = activity.completed ? "Completed" : "Pending";

            card.innerHTML = `
                <h3>${activity.name}</h3>
                <p>${activity.desc}</p>
                <p class="status ${statusClass}">Status: ${statusText}</p>
                ${!activity.completed ? `<button class="complete-btn" onclick="markCompleted(${activity.id})">Mark as Completed</button>` : ""}
            `;

            list.appendChild(card);
        });

        updateProgress();
    }

    function markCompleted(id) {
        const activity = activities.find(a => a.id === id);
        activity.completed = true;
        renderActivities();
    }

    function updateProgress() {
        const completedCount = activities.filter(a => a.completed).length;
        const totalCount = activities.length;
        document.getElementById("progressBox").innerText =
            `${completedCount} out of ${totalCount} activities completed`;
    }

    renderActivities();
</script>

</body>
</html>
